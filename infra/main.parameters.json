{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "prefix": {
      "value": "${PREFIX}"
    },
    "vnetResourceId": {
      "value": "${VNET_RESOURCE_ID}"
    },
    "foundryProjectEndpoint": {
      "value": "${AZURE_EXISTING_AIPROJECT_ENDPOINT}"
    },
    "foundryAgentId": {
      "value": "${AZURE_EXISTING_AGENT_ID}"
    },
    "foundryAgentName": {
      "value": "${AZURE_FOUNDRY_AGENT_NAME}"
    },
    "foundryAgentVersion": {
      "value": "${AZURE_FOUNDRY_AGENT_VERSION}"
    },
    "foundryProjectResourceId": {
      "value": "${AZURE_EXISTING_AIPROJECT_RESOURCE_ID}"
    },
    "foundryResourceId": {
      "value": "${AZURE_EXISTING_RESOURCE_ID}"
    },
    "foundryRoleDefinitionGuid": {
      "value": "${AZURE_FOUNDRY_ROLE_DEFINITION_GUID}"
    },
    "foundryOpenAIApiVersion": {
      "value": "${OPENAI_API_VERSION}"
    },
    "azureOpenAIApiVersion": {
      "value": "${AZURE_OPENAI_API_VERSION}"
    }
  }
}
